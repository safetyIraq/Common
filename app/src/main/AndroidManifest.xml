<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ================================================================ -->
    <!-- 🔒 الأذونات المطلوبة - Permissions                               -->
    <!-- ================================================================ -->
    
    <!-- أذونات الإنترنت (مهمة لـ Firebase) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- أذونات القراءة/الكتابة للملفات (للصور) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />

    <!-- ================================================================ -->
    <!-- 📱 التطبيق - Application                                         -->
    <!-- ================================================================ -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmptyActivity"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- ================================================================ -->
        <!-- 🏠 النشاط الرئيسي - Main Activity (يظهر عند فتح التطبيق)        -->
        <!-- ================================================================ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- ================================================================ -->
        <!-- 🔍 نشاط البحث - Search Activity (يبحث عن المستخدمين)            -->
        <!-- ================================================================ -->
        <activity 
            android:name=".SearchActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />
        
        <!-- ================================================================ -->
        <!-- 💬 نشاط المحادثة - Chat Activity (الرسائل بين المستخدمين)       -->
        <!-- ================================================================ -->
        <activity 
            android:name=".ChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />
        
        <!-- ================================================================ -->
        <!-- ⚙️ نشاط الإعدادات - Settings Activity                           -->
        <!-- ================================================================ -->
        <activity 
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />
        
    </application>

</manifest>
