<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark_main"
    android:layoutDirection="rtl">

    <!-- شريط العنوان -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_dark_card"
        android:elevation="4dp"
        app:title="الإعدادات"
        app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationContentDescription="رجوع" />

    <!-- محتوى الإعدادات -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- قسم الحساب -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الحساب"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <include layout="@layout/item_setting_row" android:id="@+id/setting_profile" />
            <include layout="@layout/item_setting_row" android:id="@+id/setting_notifications" />
            <include layout="@layout/item_setting_row" android:id="@+id/setting_privacy" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="16dp" />

            <!-- قسم التطبيق -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="التطبيق"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <include layout="@layout/item_setting_row" android:id="@+id/setting_language" />
            <include layout="@layout/item_setting_row" android:id="@+id/setting_theme" />
            <include layout="@layout/item_setting_row" android:id="@+id/setting_about" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
