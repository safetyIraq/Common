<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout android:id="@+id/loadingView" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
        <ProgressBar android:layout_width="80dp" android:layout_height="80dp" android:indeterminateTint="#00E676" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hussain Ultra Platform" android:textColor="#00E676" android:textSize="22sp" android:layout_marginTop="20dp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:id="@+id/authView" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="30dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إنشاء حساب Hussain ID" android:textColor="#FFF" android:textSize="24sp" android:layout_marginBottom="30dp" />
        <EditText android:id="@+id/regName" android:layout_width="match_parent" android:layout_height="55dp" android:hint="الاسم الكامل" android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/regUsername" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Username (يوزر نيم)" android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/regPhone" android:layout_width="match_parent" android:layout_height="55dp" android:hint="رقم الهاتف" android:textColor="#FFF" android:inputType="phone" android:background="@android:drawable/editbox_background_normal" android:layout_marginBottom="20dp" />
        <Button android:id="@+id/registerBtn" android:layout_width="match_parent" android:layout_height="60dp" android:text="دخول للمنصة 🚀" android:backgroundTint="#00E676" />
    </LinearLayout>

    <LinearLayout android:id="@+id/dashboardView" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone">
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="15dp" app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="15dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="البحث عن صديق باليوزر نيم" android:textColor="#00E676" android:layout_marginBottom="10dp"/>
                <EditText android:id="@+id/searchUsername" android:layout_width="match_parent" android:layout_height="50dp" android:hint="اكتب اليوزر هنا..." android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" />
                <Button android:id="@+id/searchBtn" android:layout_width="match_parent" android:layout_height="50dp" android:text="بحث وتواصل" android:layout_marginTop="10dp" android:backgroundTint="#2196F3" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView android:id="@+id/searchResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textColor="#00E676" android:textSize="18sp" android:layout_margin="20dp" />
    </LinearLayout>
</FrameLayout>
