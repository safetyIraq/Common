<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout android:id="@+id/loadingView" 
        android:layout_width="match_parent" 
        android:layout_height="match_parent" 
        android:gravity="center" 
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="visible">
        <ProgressBar android:layout_width="80dp" android:layout_height="80dp" android:indeterminateTint="#00E676" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="جاري تشغيل Hussain Ultra..." android:textColor="#00E676" android:layout_marginTop="15dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/authView" 
        android:layout_width="match_parent" 
        android:layout_height="match_parent" 
        android:gravity="center" 
        android:orientation="vertical" 
        android:padding="30dp" 
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="سجل يوزرك الخاص" android:textColor="#00E676" android:textSize="22sp" android:layout_marginBottom="20dp"/>
        <EditText android:id="@+id/regName" android:layout_width="match_parent" android:layout_height="55dp" 
            android:hint="الاسم" android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:layout_marginBottom="10dp" android:padding="10dp"/>
        <EditText android:id="@+id/regUser" android:layout_width="match_parent" android:layout_height="55dp" 
            android:hint="اليوزر نيم" android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:layout_marginBottom="20dp" android:padding="10dp"/>
        <Button android:id="@+id/registerBtn" android:layout_width="match_parent" android:layout_height="60dp" 
            android:text="دخول" android:backgroundTint="#00E676"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/dashboardView" 
        android:layout_width="match_parent" 
        android:layout_height="match_parent" 
        android:orientation="vertical" 
        android:padding="20dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="ابحث عن صديق" android:textColor="#00E676" android:textSize="20sp"/>
        <EditText android:id="@+id/searchField" android:layout_width="match_parent" android:layout_height="55dp" 
            android:hint="يوزر الصديق..." android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:layout_marginTop="15dp" android:padding="10dp"/>
        <Button android:id="@+id/searchBtn" android:layout_width="match_parent" android:layout_height="55dp" 
            android:text="بحث" android:layout_marginTop="10dp" android:backgroundTint="#2196F3"/>
        
        <TextView android:id="@+id/friendNameTxt" android:layout_width="match_parent" android:layout_height="wrap_content" 
            android:textColor="#FFF" android:gravity="center" android:layout_marginTop="30dp" android:textSize="18sp"/>
    </LinearLayout>

</FrameLayout>
