<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout android:id="@+id/loadingView" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
        <ProgressBar android:layout_width="70dp" android:layout_height="70dp" android:indeterminateTint="#00E676" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hussain Ultra" android:textColor="#00E676" android:textSize="22sp" android:layout_marginTop="15dp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/setupView" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="25dp" android:visibility="gone">
        <EditText android:id="@+id/tokenInput" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Bot Token" android:textColor="#FFF" android:background="@android:drawable/editbox_background_normal" android:padding="10dp" android:layout_marginBottom="10dp"/>
        <EditText android:id="@+id/chatIdInput" android:layout_width="match_parent" android:layout_height="55dp" android:hint="Chat ID" android:textColor="#FFF" android:inputType="number" android:background="@android:drawable/editbox_background_normal" android:padding="10dp" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/saveBtn" android:layout_width="match_parent" android:layout_height="55dp" android:text="حفظ وتشغيل" android:backgroundTint="#2196F3"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/mainView" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="60dp" android:padding="15dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dashboard" android:textColor="#00E676" android:textStyle="bold"/>
            <FrameLayout android:id="@+id/bellContainer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true">
                <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_popup_reminder" app:tint="#FFF" />
                <View android:id="@+id/redDot" android:layout_width="10dp" android:layout_height="10dp" android:background="#FF0000" android:layout_gravity="top|end" android:visibility="gone" />
            </FrameLayout>
        </RelativeLayout>
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="15dp" app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp">
                <EditText android:id="@+id/messageInput" android:layout_width="match_parent" android:layout_height="100dp" android:hint="رسالتك..." android:textColor="#FFF" android:gravity="top" android:background="@null"/>
                <Button android:id="@+id/sendBtn" android:layout_width="match_parent" android:layout_height="50dp" android:text="إرسال" android:backgroundTint="#00E676"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</FrameLayout>
