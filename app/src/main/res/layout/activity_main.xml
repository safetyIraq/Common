<LinearLayout 
    android:id="@+id/authView" 
    android:layout_width="match_parent" 
    android:layout_height="match_parent" 
    android:gravity="center" 
    android:orientation="vertical" 
    android:padding="25dp" 
    android:background="#000000"
    android:visibility="gone">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_lock_lock"
        app:tint="#00E676"
        android:layout_marginBottom="20dp"/>

    <TextView 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content" 
        android:text="HUSSAIN ULTRA" 
        android:textColor="#00E676" 
        android:textSize="28sp" 
        android:letterSpacing="0.1"
        android:layout_marginBottom="40dp" 
        android:textStyle="bold"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:hint="الايميل السحابي"
        app:startIconDrawable="@android:drawable/ic_dialog_email"
        app:startIconTint="#00E676"
        app:boxStrokeColor="#00E676"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="#00E676"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp">
        
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/regEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:hint="كلمة المرور"
        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
        app:startIconTint="#00E676"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#00E676"
        app:boxStrokeColor="#00E676"
        app:hintTextColor="#00E676"
        app:boxCornerRadiusAround="12dp">
        
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/regPass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:hint="يوزر نيم المنصة"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="#00E676"
        app:boxStrokeColor="#00E676"
        app:hintTextColor="#00E676"
        app:boxCornerRadiusAround="12dp">
        
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/regUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/registerBtn"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="دخول المنصة 🔥"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#00E676"
        android:textColor="#000000"
        app:cornerRadius="12dp"
        app:elevation="8dp" />

</LinearLayout>
